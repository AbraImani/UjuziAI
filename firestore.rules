rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper: Check if user is admin
    // Primary: check email directly (most reliable)
    // Fallback: check role field in user document
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email in ['abrahamfaith325@gmail.com', 'gdgoncampusucb@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Any authenticated user can read any user doc (leaderboard, profile)
      allow read: if isAuthenticated();
      
      // Users can create their own profile on signup
      allow create: if isOwner(userId);
      
      // Users can update their own profile; admins can update any
      // Any authenticated user can update bonusPoints (for auto point distribution)
      allow update: if isOwner(userId) || isAdmin() || 
        (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bonusPoints']));
      
      // Only admins can delete users
      allow delete: if isAdmin();
      
      // USER PROGRESS SUBCOLLECTION
      match /progress/{moduleId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
      
      // USER SUBMISSIONS SUBCOLLECTION
      match /submissions/{submissionId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }

      // BONUS LOGS SUBCOLLECTION
      match /bonusLogs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }
    
    // ============================================
    // EXAMS COLLECTION
    // ============================================
    match /exams/{examId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'in-progress';
      
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      
      allow delete: if isAdmin();
    }
    
    // ============================================
    // MODULE SETTINGS (Admin managed)
    // ============================================
    match /moduleSettings/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================
    // TRACKS COLLECTION (Admin managed)
    // ============================================
    match /tracks/{trackId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================
    // BADGES COLLECTION (Public verification)
    // ============================================
    match /badges/{badgeId} {
      // Anyone can read (public verification)
      allow read: if true;
      // Authenticated users can create their own badges (from exam completion)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admins can update/delete
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // APP SETTINGS (Admin managed exam config etc.)
    // ============================================
    match /appSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // TEAM PROJECTS (Collaborative projects)
    // ============================================
    match /teamProjects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && 
        (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ============================================
    // BUILDATHONS
    // ============================================
    match /buildathons/{buildathonId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      // Authenticated users can update (register as participant, etc.)
      // Admin can also update (finalize, change status)
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ============================================
    // BUILDATHON PROJECTS
    // ============================================
    match /buildathonProjects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && 
        (resource.data.submittedBy == request.auth.uid || isAdmin());
    }

    // ============================================
    // PROJECT INVITATIONS
    // ============================================
    match /projectInvitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
